apiVersion: v1
kind: Namespace
metadata:
  name: {{ jenkins_namespace }}
---
apiVersion: v1
kind: PersistentVolume
metadata:
  name: jenkins-pv
spec:
  capacity:
    storage: {{ jenkins_storage_size }}
  accessModes:
    - ReadWriteMany
  persistentVolumeReclaimPolicy: Retain
  storageClassName: ""
  nfs:
    server: {{ services_ip }}
    path: {{ jenkins_nfs_path }}
---
apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: jenkins-home
  namespace: {{ jenkins_namespace }}
spec:
  accessModes:
    - ReadWriteMany
  resources:
    requests:
      storage: {{ jenkins_storage_size }}
  storageClassName: ""
  volumeName: jenkins-pv
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: jenkins
  namespace: {{ jenkins_namespace }}
spec:
  replicas: 1
  selector:
    matchLabels:
      app: jenkins
  template:
    metadata:
      labels:
        app: jenkins
    spec:
      securityContext:
        fsGroup: 1000
      containers:
        - name: jenkins
          image: jenkins/jenkins:lts
          imagePullPolicy: IfNotPresent
          ports:
            - containerPort: {{ jenkins_http_port }}
              name: http
            - containerPort: 50000
              name: agent
          env:
            - name: JAVA_OPTS
              value: -Djenkins.install.runSetupWizard=true
          securityContext:
            runAsUser: 1000
            runAsGroup: 1000
          volumeMounts:
            - name: jenkins-home
              mountPath: /var/jenkins_home
      volumes:
        - name: jenkins-home
          persistentVolumeClaim:
            claimName: jenkins-home
---
apiVersion: v1
kind: Service
metadata:
  name: jenkins
  namespace: {{ jenkins_namespace }}
spec:
  type: NodePort
  selector:
    app: jenkins
  ports:
    - name: http
      port: {{ jenkins_http_port }}
      targetPort: http
      nodePort: {{ jenkins_nodeport }}
    - name: agent
      port: 50000
      targetPort: agent
